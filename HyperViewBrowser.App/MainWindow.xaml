<Window x:Class="HyperViewBrowser.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:HyperViewBrowser.App.Models"
        mc:Ignorable="d"
        Title="HyperView Browser" Height="820" Width="1300" MinHeight="520" MinWidth="780">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Tab" Click="NewTab_Click" InputGestureText="Ctrl+T"/>
                <MenuItem Header="New Incognito Tab" Click="NewIncognitoTab_Click"/>
                <MenuItem Header="Downloads" Click="Downloads_Click"/>
                <MenuItem Header="Clear Browsing Data" Click="ClearBrowsingData_Click"/>
                <MenuItem Header="Settings" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Bookmarks" x:Name="BookmarksMenu" SubmenuOpened="BookmarksMenu_SubmenuOpened">
                <MenuItem Header="Add Current Page" Click="AddBookmark_Click"/>
            </MenuItem>
            <MenuItem Header="_History" Click="History_Click"/>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom In" Click="ZoomIn_Click" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom Out" Click="ZoomOut_Click" InputGestureText="Ctrl+-"/>
                <MenuItem Header="Fullscreen" Click="Fullscreen_Click" InputGestureText="F11"/>
                <MenuItem Header="Find in Page" Click="Find_Click" InputGestureText="Ctrl+F"/>
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="◀" Width="32" Margin="2" Click="Back_Click"/>
            <Button Grid.Column="1" Content="▶" Width="32" Margin="2" Click="Forward_Click"/>
            <Button Grid.Column="2" Content="⟳" Width="32" Margin="2" Click="Refresh_Click"/>
            <Button Grid.Column="3" Content="⨯" Width="32" Margin="2" Click="Stop_Click"/>
            <Button Grid.Column="4" Content="🏠" Width="32" Margin="2" Click="Home_Click"/>

            <Grid Grid.Column="5" Margin="6,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HttpsLock" Text="🔓" VerticalAlignment="Center" Margin="6,0"/>
                <ComboBox x:Name="AddressBox" Grid.Column="1" IsEditable="True" IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True" KeyDown="AddressBox_KeyDown" Text="about:newtab"
                          LostKeyboardFocus="AddressBox_LostKeyboardFocus"/>
            </Grid>

            <Button Grid.Column="6" Content="☆" Width="32" Margin="2" Click="AddBookmark_Click"/>
            <Button Grid.Column="7" Content="+" Width="32" Margin="2" Click="NewTab_Click"/>
            <Button Grid.Column="8" Content="⚙" Width="32" Margin="2" Click="Settings_Click"/>
        </Grid>

        <TabControl x:Name="Tabs" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" SelectionChanged="Tabs_SelectionChanged" AllowDrop="True" PreviewMouseMove="Tabs_PreviewMouseMove" Drop="Tabs_Drop">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:BrowserTab}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Title}" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                        <Button Content="x" Margin="6,0,0,0" Padding="2" CommandParameter="{Binding}" Click="CloseTab_Click"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type models:BrowserTab}">
                    <Grid>
                        <ContentControl x:Name="WebHost" Loaded="WebHost_Loaded"/>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>
